{
  "name": "@saas/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "tsc && drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env src/migrate.ts",
    "db:seed": "tsx --env-file=../../.env src/seed/demo-seed.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@saas/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "rimraf": "^6.0.1"
  }
}
