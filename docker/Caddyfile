# Caddy reverse proxy — HTTPS automático via Let's Encrypt
# Set DOMAIN in .env (e.g. DOMAIN=app.tudominio.co)

{$DOMAIN} {
  # Web app (Next.js)
  handle /* {
    reverse_proxy web:3000
  }

  # API routes
  handle /api/* {
    reverse_proxy api:3001
  }

  # SSE — inbox tiempo real
  handle /api/conversations/stream* {
    reverse_proxy api:3001 {
      flush_interval -1
    }
  }

  # SSE — WhatsApp QR streaming
  handle /api/channels/whatsapp/stream* {
    reverse_proxy api:3001 {
      flush_interval -1
    }
  }

  # Evolution API webhook (public)
  handle /api/webhooks/evolution* {
    reverse_proxy api:3001
  }

  # Security headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    -Server
  }

  # Compression
  encode gzip

  # Access log
  log {
    output file /data/logs/access.log {
      roll_size 100mb
      roll_keep 5
    }
  }
}
